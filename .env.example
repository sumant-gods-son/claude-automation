# GreenTec Automation - Environment Variables
# Copy this to .env for local testing
# Set all these in Render.com dashboard > Environment

# SerpAPI - free at serpapi.com (100 searches/month free)
SERPAPI_KEY=your_serpapi_key_here

# GoHighLevel API Key
# GHL > Settings > API Keys > Create Key
GHL_API_KEY=your_ghl_api_key_here

# GHL Sub-account Location ID
# GHL > Settings > Business Profile > Location ID
GHL_LOCATION_ID=your_location_id_here

# Dashboard port (Render sets this automatically)
PORT=5050
